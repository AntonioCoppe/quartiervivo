    "data:fetch": "node scripts/fetch-national-data.mjs",
    "data:unpack": "node scripts/unpack-national-data.mjs",
    "data:build": "node scripts/build-national-dataset.mjs",
    "data:map": "node scripts/build-map-artifacts.mjs",
    "data:all": "npm run data:build && npm run data:map"
  },
  "dependencies": {
    "lucide-react": "latest",
    "maplibre-gl": "latest",
    "pmtiles": "^4.4.1",
